{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma migrate deploy && next build",
  "crons": [
    {
      "path": "/api/cron/expire-pending",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/event-reminders",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/cleanup-audit",
      "schedule": "30 4 * * *"
    }
  ]
}
