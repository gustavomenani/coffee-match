# Postgres — use 5432 por padrão; se ocupada, mapeie Docker em 5437 e ajuste a URL:
#   docker run -d --name speeddate-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=speeddate -p 5437:5432 postgres:16
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5437/speeddate?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/speeddate?schema=public"

# Auth.js — gere com: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Mercado Pago
# Sandbox real: access token de teste (ex.: TEST-xxxx...)
# Dev local / E2E sem MP: TEST-DEV-BYPASS (marca ticket pago e redireciona para /pagamento/sucesso)
MERCADOPAGO_ACCESS_TOKEN="TEST-DEV-BYPASS"
MERCADOPAGO_WEBHOOK_SECRET="whsec-xxx"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
