# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5437/coffeematch?schema=public"

# Auth.js — production: openssl rand -base64 32 (min 32 chars, no "change-me")
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Mercado Pago
# Production: real access token (APP_USR-...) — NEVER TEST-DEV-BYPASS
# Local free checkout: ALLOW_DEV_BYPASS=1 and MERCADOPAGO_ACCESS_TOKEN=TEST-DEV-BYPASS
MERCADOPAGO_ACCESS_TOKEN="TEST-DEV-BYPASS"
ALLOW_DEV_BYPASS="1"
# Webhook secret from MP dashboard (required in production)
MERCADOPAGO_WEBHOOK_SECRET="whsec-xxx"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional email (Resend). If unset, ticket emails log to server console + audit.
# RESEND_API_KEY="re_xxx"
# EMAIL_FROM="Coffee Match <ingressos@seudominio.com>"

# Tests only
# E2E_DISABLE_RATE_LIMIT="1"

# Segredo (min 16 chars) que protege as rotas de cron:
#   GET /api/cron/expire-pending   - cancela ingressos pendentes vencidos
#   GET /api/cron/event-reminders  - envia o e-mail lembrete D-1 dos ingressos pagos
#   GET /api/cron/cleanup-audit    - apaga audit logs com +90 dias (retencao)
# O agendador externo (ex.: Vercel Cron, GitHub Actions schedule, crontab) deve chamar a rota
# com o header: Authorization: Bearer $CRON_SECRET. Sem essa variavel a rota responde 503.
CRON_SECRET="troque-por-um-segredo-longo-aleatorio"

# Web Push (VAPID) — opcional; sem as chaves o recurso fica desligado.
# Gere o par com: npx web-push generate-vapid-keys  (ou: npm run push:keys)
# A public key NÃO precisa ser duplicada como NEXT_PUBLIC_: o client a
# obtém pela server action getVapidPublicKey().
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# mailto: do responsável ou URL https do site
VAPID_SUBJECT="mailto:contato@example.com"
